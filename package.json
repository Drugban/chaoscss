{
	"name": "chaoscss",
	"version": "1.1.1",
	"description": "ChaosCSS - is a free and simple open source CSS library.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Drugban/chaoscss"
	},
	"keywords": [
		"front-end",
		"framework",
		"css",
		"sass",
		"responsive"
	],
	"main": "scss/chaos.scss",
	"author": "The ChaosCss authors (https://github.com/Drugban/chaoscss/graphs/contributors)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Drugban/chaoscss/issues"
	},
	"homepage": "chaoscss.vercel.app",
	"files": [
		"css/*",
		"scss/*"
	],
	"scripts": {
		"dev": "vite --port 1000",
		"build": "tsc -b && vite build",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview --port 1001"
	},
	"dependencies": {
		"algoliasearch": "^4.24.0",
		"clsx": "^2.1.1",
		"postcss": "^8.4.40",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-instantsearch": "^7.12.3",
		"react-router": "^6.25.1",
		"react-router-dom": "^6.25.1"
	},
	"devDependencies": {
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@typescript-eslint/eslint-plugin": "^7.15.0",
		"@typescript-eslint/parser": "^7.15.0",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.19",
		"eslint": "^8.57.0",
		"eslint-plugin-react-hooks": "^4.6.2",
		"eslint-plugin-react-refresh": "^0.4.7",
		"prettier": "^3.3.3",
		"sass": "^1.77.8",
		"stylelint": "^16.7.0",
		"typescript": "^5.2.2",
		"typescript-plugin-css-modules": "^5.1.0",
		"vite": "^5.3.4",
		"vite-plugin-svgr": "^4.2.0"
	}
}
